pluginManagement {
    repositories {
        google()
        mavenCentral()
        gradlePluginPortal()
    }
}

dependencyResolutionManagement {
    // PREFER_PROJECT מאפשר לנו להגדיר מאגרים גם ב-build.gradle הראשי בלי שגראדל יזרוק שגיאה
    repositoriesMode.set(RepositoriesMode.PREFER_PROJECT)
    repositories {
        google()
        mavenCentral()
    }
}

// הגדרת שם הפרויקט וחיבור מודול האפליקציה שפותר את שגיאת ה-Task not found
rootProject.name = "crt-all"
include ':app'
